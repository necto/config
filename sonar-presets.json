{
  "version": 6,
  "configurePresets": [
    {
      "name": "asserts",
      "inherits": "linux-asserted-release",
      "binaryDir": "build/asserts",
      "cacheVariables": {
        "CMAKE_VERBOSE_MAKEFILE": "OFF",
        "USE_LLVM_SOURCE": "$penv{HOME}/proj/llvm-project/",
        "CMAKE_C_COMPILER_CLANG_SCAN_DEPS": "$penv{HOME}/.guix-profile/bin/clang-scan-deps",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "$penv{HOME}/.guix-profile/bin/clang-scan-deps"
      },
      "environment": {
        "CCACHE_BASEDIR": "${sourceDir}"
      }
    },
    {
      "name": "debug",
      "inherits": "linux-debug",
      "binaryDir": "build/debug",
      "cacheVariables": {
        "CMAKE_VERBOSE_MAKEFILE": "OFF",
        "USE_LLVM_SOURCE": "$penv{HOME}/proj/llvm-project/",
        "CMAKE_C_COMPILER_CLANG_SCAN_DEPS": "$penv{HOME}/.guix-profile/bin/clang-scan-deps",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "$penv{HOME}/.guix-profile/bin/clang-scan-deps"
      },
      "environment": {
        "CCACHE_BASEDIR": "${sourceDir}"
      }
    },
    {
      "name": "pluginAsserts",
      "inherits": "linux-asserted-release",
      "binaryDir": "build/plugin-asserts",
      "cacheVariables": {
        "CMAKE_VERBOSE_MAKEFILE": "OFF",
        "CMAKE_C_COMPILER_CLANG_SCAN_DEPS": "$penv{HOME}/.guix-profile/bin/clang-scan-deps",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "$penv{HOME}/.guix-profile/bin/clang-scan-deps"
      },
      "environment": {
        "CCACHE_BASEDIR": "${sourceDir}"
      }
    },
    {
      "name": "release",
      "inherits": "linux-release",
      "binaryDir": "build/release",
      "cacheVariables": {
        "CMAKE_VERBOSE_MAKEFILE": "OFF",
        "CMAKE_C_COMPILER_CLANG_SCAN_DEPS": "$penv{HOME}/.guix-profile/bin/clang-scan-deps",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "$penv{HOME}/.guix-profile/bin/clang-scan-deps"
      },
      "environment": {
        "CCACHE_BASEDIR": "${sourceDir}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "asserts",
      "configurePreset": "asserts",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "pluginAsserts",
      "configurePreset": "pluginAsserts",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "release",
      "configurePreset": "release",
      "inheritConfigureEnvironment": true
    }
  ]
}
